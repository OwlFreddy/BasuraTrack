<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/basura_bg"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:layout_marginTop="60dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@color/basura_white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BasuraTrack Dashboard"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/basura_green_dark"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/basura_text_dark"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/basura_text_gray"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvBarangay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/basura_text_gray"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/basura_text_gray"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/btnViewSchedules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View Collection Schedules"
                android:textColor="@color/basura_white"
                android:textAllCaps="false"
                android:background="@drawable/bg_button_green"
                android:padding="14dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Log Out"
                android:textColor="@color/basura_white"
                android:textAllCaps="false"
                android:background="@drawable/bg_button_green"
                android:padding="14dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>